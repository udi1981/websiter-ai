{
  "name": "ubuilder",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "db:push": "pnpm --filter @ubuilder/db db:push",
    "db:studio": "pnpm --filter @ubuilder/db db:studio",
    "db:generate": "pnpm --filter @ubuilder/db db:generate",
    "db:migrate": "pnpm --filter @ubuilder/db db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}
